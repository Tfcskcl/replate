# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/replate
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk) ─────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET_NAME=replate-videos
CLOUDFLARE_R2_PUBLIC_URL=https://videos.re-plate.in

# ── AI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
SECRET_KEY=change-this-in-production-minimum-32-chars

# ── Edge device (set on RPi, not in web/api) ─────────────────────────────
# REPLATE_OUTLET_ID=outlet_uuid_here
# REPLATE_DEVICE_ID=device_uuid_here
# REPLATE_API_URL=https://api.re-plate.in
# REPLATE_API_KEY=your_device_api_key
# CAMERA_SOURCE=usb
# USB_DEVICE=0
# CCTV_RTSP_URL=rtsp://admin:password@192.168.1.64/Streaming/Channels/101
